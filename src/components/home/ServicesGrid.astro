---
import { getCollection } from 'astro:content';
import { useTranslations, type LanguageCode } from '@i18n/utils';
import Heading from '@components/ui/Heading.astro';
import Card from '@components/ui/Card.astro';
import Icon from '@components/ui/Icon.astro';
import Badge from '@components/ui/Badge.astro';

interface Props { lang: LanguageCode; }
const { lang } = Astro.props;
const t = useTranslations(lang);

const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);
---
<section class="section bg-surface">
  <div class="container max-w-[1280px]">
    <Heading
      level={2}
      size="xl"
      eyebrow={t('common.new')}
      subtitle={t('services.sectionSubtitle')}
      align="center"
    >
      {t('services.sectionTitle')}
    </Heading>

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4 mt-12">
      {services.map((service) => (
        <Card href={`${import.meta.env.BASE_URL}${lang}/services/${service.data.slug}`} variant="outline" padding="lg" class="group h-full flex flex-col">
          <div class="flex items-start justify-between mb-4">
            <span class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-navy/5 text-navy group-hover:bg-navy group-hover:text-teal transition-colors">
              <Icon name={service.data.icon} size={28} />
            </span>
            {service.data.free && <Badge variant="success">{t('common.free')}</Badge>}
          </div>
          <h3 class="text-xl font-bold text-navy mb-2">{service.data.title[lang]}</h3>
          <p class="text-ink-muted text-sm leading-relaxed flex-1">{service.data.shortDescription[lang]}</p>
          {service.data.hours && (
            <p class="mt-3 text-xs text-teal-700 font-semibold flex items-center gap-1.5">
              <Icon name="clock" size={14} />
              {service.data.hours[lang]}
            </p>
          )}
          <div class="mt-4 inline-flex items-center gap-1.5 text-navy font-semibold text-sm group-hover:gap-2.5 transition-all">
            <span>{t('services.viewService')}</span>
            <Icon name="arrow-end" size={16} />
          </div>
        </Card>
      ))}
    </div>
  </div>
</section>
