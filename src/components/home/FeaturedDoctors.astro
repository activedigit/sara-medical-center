---
import { getCollection } from 'astro:content';
import { useTranslations, type LanguageCode } from '@i18n/utils';
import Heading from '@components/ui/Heading.astro';
import Card from '@components/ui/Card.astro';
import Icon from '@components/ui/Icon.astro';
import DoctorAvatar from '@components/doctors/DoctorAvatar.astro';

interface Props { lang: LanguageCode; }
const { lang } = Astro.props;
const t = useTranslations(lang);

const doctors = (await getCollection('doctors'))
  .filter((d) => d.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
---
<section class="section bg-surface-alt">
  <div class="container max-w-[1280px]">
    <Heading
      level={2}
      size="xl"
      eyebrow={t('common.new')}
      subtitle={t('doctors.sectionSubtitle')}
      align="center"
    >
      {t('doctors.sectionTitle')}
    </Heading>

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3 mt-12">
      {doctors.map((doctor) => (
        <Card href={`${import.meta.env.BASE_URL}${lang}/doctors/${doctor.data.slug}`} variant="default" padding="lg" hoverable={true} class="text-center">
          <DoctorAvatar name={doctor.data.name.en} photo={doctor.data.photo} alt={doctor.data.portraitAlt ?? doctor.data.name[lang]} size="sm" class="mx-auto mb-4" />
          <h3 class="text-lg font-bold text-navy">{doctor.data.name[lang]}</h3>
          <p class="text-sm text-teal-700 font-semibold mt-1">{doctor.data.specialty[lang]}</p>
          <p class="mt-3 text-sm text-ink-muted leading-relaxed">{doctor.data.shortBio[lang]}</p>
          {doctor.data.schedule && (
            <p class="mt-3 text-xs text-ink-subtle flex items-center justify-center gap-1.5">
              <Icon name="clock" size={12} />
              {doctor.data.schedule[lang]}
            </p>
          )}
        </Card>
      ))}
    </div>

    <div class="text-center mt-10">
      <a href={`${import.meta.env.BASE_URL}${lang}/doctors/`} class="inline-flex items-center gap-2 text-navy font-semibold hover:gap-3 transition-all">
        <span>{t('common.viewAll')}</span>
        <Icon name="arrow-end" size={18} />
      </a>
    </div>
  </div>
</section>
