---
import { type LanguageCode } from '@i18n/utils';
import { SITE } from '~/config/site';

interface Props { lang: LanguageCode; }
const { lang } = Astro.props;

// Single large branded banner (high-res, self-contained with the SARA logo)
const banner = '/images/slider/00-clinic-banner.png';
---
<div class="relative w-full">
  <div class="absolute -inset-3 bg-teal/20 rounded-3xl blur-2xl" aria-hidden="true"></div>
  <img
    src={banner}
    alt={SITE.name[lang]}
    width="1916"
    height="821"
    loading="eager"
    decoding="async"
    class="relative w-full h-auto rounded-3xl border border-white/15 shadow-floating"
  />
</div>
