---
import { useTranslations, withBase, type LanguageCode } from '@i18n/utils';
import Heading from '@components/ui/Heading.astro';
import Icon from '@components/ui/Icon.astro';

interface Props { lang: LanguageCode; }
const { lang } = Astro.props;
const t = useTranslations(lang);

type L = { ar: string; he: string; en: string };
interface Tip { img: string; href: string; title: L; desc: L; }

const ui = {
  eyebrow: { ar: 'مركز سارة يهتم بصحتك', he: 'מרכז שארה דואג לבריאותכם', en: 'We care about your health' },
  title: { ar: 'نصائح وإرشادات صحية', he: 'טיפים והכוונה לבריאות', en: 'Health Tips & Guidance' },
  subtitle: { ar: 'مواضيع توعوية من فريقنا الطبي لمختلف الفئات', he: 'תכנים מקצועיים מהצוות הרפואי שלנו לכל המשפחה', en: 'Awareness topics from our medical team for the whole family' },
  readMore: { ar: 'اقرأ المزيد', he: 'קראו עוד', en: 'Read more' },
};

const tips: Tip[] = [
  {
    img: '/images/tips/immunity.jpg', href: `/${lang}/services/general-medicine`,
    title: { ar: 'فيتامينات لمناعة قوية', he: 'ויטמינים לחיסון חזק', en: 'Vitamins for strong immunity' },
    desc: { ar: 'كيف تعزّز مناعتك بالتغذية السليمة خلال موسم البرد والإنفلونزا.', he: 'כיצד לחזק את מערכת החיסון בתזונה נכונה בעונת הקור.', en: 'Boost your immunity with proper nutrition during the cold and flu season.' },
  },
  {
    img: '/images/tips/ortho.jpg', href: `/${lang}/services/emergency`,
    title: { ar: 'صحة العظام والمفاصل', he: 'בריאות עצמות ומפרקים', en: 'Bone & joint health' },
    desc: { ar: 'نصائح للوقاية من إصابات العظام والعناية بالمفاصل بعد الإصابة.', he: 'טיפים למניעת פציעות עצם וטיפול נכון במפרקים.', en: 'Tips to prevent bone injuries and care for your joints after an injury.' },
  },
  {
    img: '/images/tips/pediatrics.jpg', href: `/${lang}/services/pediatrics`,
    title: { ar: 'متابعة نمو طفلك', he: 'מעקב אחר התפתחות ילדכם', en: "Your child's growth" },
    desc: { ar: 'أهمية الفحوصات الدورية لمتابعة صحة ونمو الأطفال في كل مرحلة.', he: 'חשיבות הבדיקות התקופתיות למעקב אחר בריאות והתפתחות הילד.', en: 'The importance of regular check-ups to follow your child’s health and growth.' },
  },
  {
    img: '/images/tips/mental-health.jpg', href: `/${lang}/booking`,
    title: { ar: 'العناية بالصحة النفسية', he: 'טיפוח הבריאות הנפשית', en: 'Caring for mental health' },
    desc: { ar: 'الاهتمام بالصحة النفسية ليس رفاهية — متى تطلب الدعم والمشورة.', he: 'הטיפול בבריאות הנפש אינו מותרות — מתי לפנות לתמיכה.', en: 'Mental wellbeing is not a luxury — when to seek support and advice.' },
  },
  {
    img: '/images/tips/allergy.jpg', href: `/${lang}/services/general-medicine`,
    title: { ar: 'التعامل مع الحساسية الموسمية', he: 'התמודדות עם אלרגיה עונתית', en: 'Managing seasonal allergies' },
    desc: { ar: 'أعراض الحساسية الموسمية وطرق الوقاية منها والتعامل معها.', he: 'תסמיני האלרגיה העונתית ודרכים למנוע ולהתמודד.', en: 'Symptoms of seasonal allergies and how to prevent and manage them.' },
  },
  {
    img: '/images/tips/kids-immunity.jpg', href: `/${lang}/services/pediatrics`,
    title: { ar: 'مناعة قوية لأطفالك', he: 'חיסון חזק לילדים', en: 'Strong immunity for kids' },
    desc: { ar: 'عادات صحية بسيطة تحمي أطفالك وتقوّي مناعتهم طوال العام.', he: 'הרגלים בריאים פשוטים שיגנו על ילדיכם ויחזקו את חיסונם.', en: 'Simple healthy habits that protect your kids and strengthen their immunity.' },
  },
];

// Repeat the list enough times so the row always fills wide screens; the
// animation shifts by exactly one copy (-25% of 4 copies) for a seamless loop.
const loop = [...tips, ...tips, ...tips, ...tips];
---
<section class="section bg-surface-alt overflow-hidden">
  <div class="container max-w-[1280px]">
    <Heading level={2} size="xl" eyebrow={ui.eyebrow[lang]} subtitle={ui.subtitle[lang]} align="center">
      {ui.title[lang]}
    </Heading>
  </div>

  <!-- Auto-scrolling single-row marquee (LTR viewport so the track anchors left and never leaves a gap) -->
  <div class="tips-viewport relative mt-10" dir="ltr">
    <div class="tips-track flex w-max" dir="ltr">
      {loop.map((tip, i) => (
        <article class="group shrink-0 w-[290px] mr-6 flex" dir={lang === 'en' ? 'ltr' : 'rtl'} aria-hidden={i >= tips.length ? 'true' : undefined}>
          <a href={withBase(tip.href)} class="flex flex-col w-full bg-white rounded-3xl shadow-card overflow-hidden hover:shadow-cardHover transition-shadow focus-visible:outline-none" tabindex={i >= tips.length ? -1 : undefined}>
            <div class="aspect-[4/3] relative bg-navy-700 overflow-hidden">
              <div class="absolute inset-0 overflow-hidden" aria-hidden="true">
                <img src={withBase(tip.img)} alt="" class="w-full h-full object-cover scale-125 blur-2xl opacity-50" />
                <div class="absolute inset-0 bg-navy/30"></div>
              </div>
              <img
                src={withBase(tip.img)}
                alt={tip.title[lang]}
                loading="lazy"
                decoding="async"
                class="relative z-[1] w-full h-full object-contain transition-transform duration-500 group-hover:scale-105"
              />
            </div>
            <div class="p-5 flex flex-col flex-1">
              <h3 class="font-bold text-navy text-lg mb-2 group-hover:text-teal-700 transition-colors line-clamp-1">{tip.title[lang]}</h3>
              <p class="text-sm text-ink-muted leading-relaxed line-clamp-2 flex-1">{tip.desc[lang]}</p>
              <span class="inline-flex items-center gap-2 mt-4 text-sm font-semibold text-teal-700">
                <span class="inline-flex w-7 h-7 rounded-full bg-teal/15 items-center justify-center group-hover:bg-teal group-hover:text-navy transition-colors">
                  <Icon name="arrow-end" size={14} class="rotate-180 icon-flip-rtl" />
                </span>
                {ui.readMore[lang]}
              </span>
            </div>
          </a>
        </article>
      ))}
    </div>
    <!-- Edge fades -->
    <div class="pointer-events-none absolute inset-y-0 start-0 w-12 md:w-20 bg-gradient-to-r from-surface-alt to-transparent z-10"></div>
    <div class="pointer-events-none absolute inset-y-0 end-0 w-12 md:w-20 bg-gradient-to-l from-surface-alt to-transparent z-10"></div>
  </div>
</section>

<style>
  @keyframes tips-marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-25%); }
  }
  .tips-track {
    animation: tips-marquee 45s linear infinite;
    will-change: transform;
  }
  .tips-viewport:hover .tips-track,
  .tips-viewport:focus-within .tips-track {
    animation-play-state: paused;
  }
  @media (prefers-reduced-motion: reduce) {
    .tips-track { animation: none; }
    .tips-viewport { overflow-x: auto; }
  }
</style>
