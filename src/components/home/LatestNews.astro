---
import { getCollection } from 'astro:content';
import { useTranslations, type LanguageCode } from '@i18n/utils';
import Heading from '@components/ui/Heading.astro';
import Card from '@components/ui/Card.astro';
import Icon from '@components/ui/Icon.astro';
import Badge from '@components/ui/Badge.astro';
import NewsCover from '@components/news/NewsCover.astro';

interface Props { lang: LanguageCode; }
const { lang } = Astro.props;
const t = useTranslations(lang);

const newsPosts = (await getCollection('news', (post) => post.data.lang === lang && !post.data.draft))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);

const formatDate = (date: Date) => {
  const localeCode = lang === 'ar' ? 'ar-EG' : lang === 'he' ? 'he-IL' : 'en-US';
  return new Intl.DateTimeFormat(localeCode, { year: 'numeric', month: 'long', day: 'numeric' }).format(date);
};
---
{newsPosts.length > 0 && (
  <section class="section bg-surface">
    <div class="container max-w-[1280px]">
      <Heading
        level={2}
        size="xl"
        eyebrow={t('common.new')}
        subtitle={t('news.sectionSubtitle')}
        align="center"
      >
        {t('news.sectionTitle')}
      </Heading>

      <div class="grid gap-6 md:grid-cols-3 mt-12">
        {newsPosts.map((post) => (
          <Card href={`${import.meta.env.BASE_URL}${lang}/news/${post.slug.replace(/^[a-z]+\//, '')}`} variant="outline" padding="md" hoverable={true} class="h-full flex flex-col">
            <NewsCover cover={post.data.cover} alt={post.data.heroImageAlt ?? post.data.title} />
            <div class="flex flex-wrap gap-2 mb-3">
              {post.data.featured && <Badge variant="teal" size="sm">{t('common.new')}</Badge>}
              {post.data.tags.slice(0, 1).map((tag) => (
                <Badge variant="default" size="sm">{tag}</Badge>
              ))}
            </div>
            <h3 class="text-lg font-bold text-navy mb-2 line-clamp-2">{post.data.title}</h3>
            <p class="text-sm text-ink-muted leading-relaxed line-clamp-3 flex-1">{post.data.excerpt}</p>
            <div class="mt-4 flex items-center justify-between text-xs">
              <time class="text-ink-subtle" datetime={post.data.publishDate.toISOString()}>{formatDate(post.data.publishDate)}</time>
              <span class="inline-flex items-center gap-1 text-navy font-semibold">
                <span>{t('news.readArticle')}</span>
                <Icon name="arrow-end" size={14} />
              </span>
            </div>
          </Card>
        ))}
      </div>

      <div class="text-center mt-10">
        <a href={`${import.meta.env.BASE_URL}${lang}/news/`} class="inline-flex items-center gap-2 text-navy font-semibold hover:gap-3 transition-all">
          <span>{t('common.viewAll')}</span>
          <Icon name="arrow-end" size={18} />
        </a>
      </div>
    </div>
  </section>
)}
