---
import Icon from '@components/ui/Icon.astro';

interface Props {
  cover?: string;
  alt: string;
  class?: string;
}
const { cover, alt, class: className = '' } = Astro.props;
---
<div class:list={['aspect-[16/9] -m-6 mb-4 rounded-t-2xl overflow-hidden relative bg-gradient-to-br from-navy to-navy-700', className]}>
  {cover ? (
    <Fragment>
      <div class="absolute inset-0 overflow-hidden" aria-hidden="true">
        <img src={cover} alt="" class="w-full h-full object-cover scale-125 blur-2xl opacity-50" />
        <div class="absolute inset-0 bg-navy/40"></div>
      </div>
      <img
        src={cover}
        alt={alt}
        loading="lazy"
        decoding="async"
        class="relative z-[1] w-full h-full object-contain"
      />
    </Fragment>
  ) : (
    <div class="absolute inset-0 flex items-center justify-center">
      <Icon name="calendar" size={48} class="text-teal/60" />
    </div>
  )}
</div>
