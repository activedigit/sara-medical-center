---
import type { CollectionEntry } from 'astro:content';
import type { LanguageCode } from '@i18n/utils';
import { useTranslations } from '@i18n/utils';
import Card from '@components/ui/Card.astro';
import Icon from '@components/ui/Icon.astro';
import Badge from '@components/ui/Badge.astro';
import NewsCover from '@components/news/NewsCover.astro';

interface Props { post: CollectionEntry<'news'>; lang: LanguageCode; }
const { post, lang } = Astro.props;
const t = useTranslations(lang);
const slug = post.slug.replace(/^[a-z]+\//, '');
const localeCode = lang === 'ar' ? 'ar-EG' : lang === 'he' ? 'he-IL' : 'en-US';
const formattedDate = new Intl.DateTimeFormat(localeCode, { year: 'numeric', month: 'long', day: 'numeric' }).format(post.data.publishDate);
---
<Card href={`/${lang}/news/${slug}`} variant="outline" padding="md" hoverable={true} class="h-full flex flex-col group">
  <NewsCover cover={post.data.cover} alt={post.data.heroImageAlt ?? post.data.title} />
  <div class="flex flex-wrap gap-2 mb-3">
    {post.data.featured && <Badge variant="teal" size="sm">{t('common.new')}</Badge>}
    {post.data.tags.slice(0, 2).map((tag) => (
      <Badge variant="default" size="sm">{tag}</Badge>
    ))}
  </div>
  <h3 class="text-lg font-bold text-navy mb-2 line-clamp-2 group-hover:text-teal-700 transition-colors">{post.data.title}</h3>
  <p class="text-sm text-ink-muted leading-relaxed line-clamp-3 flex-1">{post.data.excerpt}</p>
  <div class="mt-4 flex items-center justify-between text-xs pt-3 border-t border-surface-tint">
    <time class="text-ink-subtle" datetime={post.data.publishDate.toISOString()}>{formattedDate}</time>
    <span class="inline-flex items-center gap-1 text-navy font-semibold">
      <span>{t('news.readArticle')}</span>
      <Icon name="arrow-end" size={14} />
    </span>
  </div>
</Card>
