---
interface Props {
  name: string;
  label: string;
  type?: 'text' | 'email' | 'tel' | 'date' | 'time' | 'textarea';
  required?: boolean;
  placeholder?: string;
  value?: string;
  dir?: 'auto' | 'ltr' | 'rtl';
  pattern?: string;
  rows?: number;
  autocomplete?: string;
}
const {
  name, label, type = 'text', required = false, placeholder, value, dir = 'auto', pattern, rows = 4, autocomplete,
} = Astro.props;
---
<div class="space-y-1.5">
  <label for={name} class="block text-sm font-semibold text-ink">
    {label}
    {required && <span class="text-accent-emergency ms-1" aria-hidden="true">*</span>}
  </label>
  {type === 'textarea' ? (
    <textarea
      id={name}
      name={name}
      rows={rows}
      placeholder={placeholder}
      required={required}
      dir={dir}
      autocomplete={autocomplete}
      class="w-full px-4 py-3 rounded-xl border border-surface-tint focus:border-navy focus:ring-2 focus:ring-navy/20 focus:outline-none text-ink placeholder:text-ink-subtle resize-y"
    >{value}</textarea>
  ) : (
    <input
      type={type}
      id={name}
      name={name}
      placeholder={placeholder}
      required={required}
      value={value}
      dir={dir}
      pattern={pattern}
      autocomplete={autocomplete}
      class="w-full px-4 py-3 rounded-xl border border-surface-tint focus:border-navy focus:ring-2 focus:ring-navy/20 focus:outline-none text-ink placeholder:text-ink-subtle"
    />
  )}
</div>
