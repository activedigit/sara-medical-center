---
interface Option { value: string; label: string; }
interface Props {
  name: string;
  label: string;
  options: Option[];
  required?: boolean;
  placeholder?: string;
  defaultValue?: string;
}
const { name, label, options, required = false, placeholder, defaultValue } = Astro.props;
---
<div class="space-y-1.5">
  <label for={name} class="block text-sm font-semibold text-ink">
    {label}
    {required && <span class="text-accent-emergency ms-1" aria-hidden="true">*</span>}
  </label>
  <select
    id={name}
    name={name}
    required={required}
    class="w-full px-4 py-3 rounded-xl border border-surface-tint bg-white focus:border-navy focus:ring-2 focus:ring-navy/20 focus:outline-none text-ink"
  >
    {placeholder && <option value="">{placeholder}</option>}
    {options.map((opt) => (
      <option value={opt.value} selected={defaultValue === opt.value}>{opt.label}</option>
    ))}
  </select>
</div>
