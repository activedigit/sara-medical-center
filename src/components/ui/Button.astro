---
interface Props {
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost' | 'emergency' | 'whatsapp' | 'teal';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  ariaLabel?: string;
  fullWidth?: boolean;
  target?: string;
  rel?: string;
  class?: string;
  [key: string]: any;
}
const {
  variant = 'primary',
  size = 'md',
  href,
  type = 'button',
  ariaLabel,
  fullWidth = false,
  target,
  rel,
  class: className = '',
  ...rest
} = Astro.props;

const base = 'inline-flex items-center justify-center gap-2 font-semibold rounded-xl transition-all duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-navy disabled:opacity-50 disabled:cursor-not-allowed whitespace-nowrap';

const variants = {
  primary: 'bg-navy text-white hover:bg-navy-600 shadow-card hover:shadow-cardHover',
  secondary: 'bg-white text-navy border-2 border-navy hover:bg-navy hover:text-white',
  outline: 'bg-transparent text-navy border-2 border-navy/20 hover:border-navy hover:bg-navy/5',
  ghost: 'bg-transparent text-navy hover:bg-navy/5',
  emergency: 'bg-accent-emergency text-white hover:bg-teal-800 shadow-emergency',
  whatsapp: 'bg-accent-whatsapp text-white hover:bg-green-600 shadow-card',
  teal: 'bg-teal text-navy hover:bg-teal-600 hover:text-white shadow-card',
};

const sizes = {
  sm: 'px-3 py-2 text-sm',
  md: 'px-5 py-3 text-base',
  lg: 'px-7 py-4 text-lg',
};

const classes = [base, variants[variant], sizes[size], fullWidth && 'w-full', className];

const Tag = href ? 'a' : 'button';
const attrs: Record<string, any> = href
  ? { href, target, rel: rel ?? (target === '_blank' ? 'noopener noreferrer' : undefined) }
  : { type };
---
<Tag class:list={classes} aria-label={ariaLabel} {...attrs} {...rest}>
  <slot />
</Tag>
