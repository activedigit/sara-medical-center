---
interface Props {
  variant?: 'default' | 'teal' | 'navy' | 'emergency' | 'success' | 'outline';
  size?: 'sm' | 'md';
  class?: string;
}
const { variant = 'default', size = 'sm', class: className = '' } = Astro.props;
const variants = {
  default: 'bg-surface-tint text-ink',
  teal: 'bg-teal/15 text-teal-700',
  navy: 'bg-navy/10 text-navy',
  emergency: 'bg-accent-emergency/10 text-accent-emergency',
  success: 'bg-accent-success/10 text-accent-success',
  outline: 'bg-transparent text-ink-muted border border-current',
};
const sizes = {
  sm: 'px-2.5 py-0.5 text-xs',
  md: 'px-3 py-1 text-sm',
};
---
<span class:list={['inline-flex items-center gap-1 font-semibold rounded-full', variants[variant], sizes[size], className]}>
  <slot />
</span>
