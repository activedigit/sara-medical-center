---
import { useTranslations, type LanguageCode } from '@i18n/utils';
import { SITE } from '~/config/site';
import Icon from '@components/ui/Icon.astro';

interface Props { lang: LanguageCode; }
const { lang } = Astro.props;
const t = useTranslations(lang);
const year = 2026;

const quickLinks = [
  { href: `${import.meta.env.BASE_URL}${lang}/about`, key: 'nav.about' },
  { href: `${import.meta.env.BASE_URL}${lang}/services/`, key: 'nav.services' },
  { href: `${import.meta.env.BASE_URL}${lang}/doctors/`, key: 'nav.doctors' },
  { href: `${import.meta.env.BASE_URL}${lang}/insurance`, key: 'nav.insurance' },
  { href: `${import.meta.env.BASE_URL}${lang}/news/`, key: 'nav.news' },
  { href: `${import.meta.env.BASE_URL}${lang}/booking`, key: 'nav.booking' },
];

const hours = [
  { label: t('hours.sundayThursday'), value: '08:00 – 22:00' },
  { label: t('hours.friday'), value: '08:00 – 14:00' },
  { label: t('hours.saturday'), value: '08:30 – 18:00' },
];
---
<footer class="bg-navy text-white mt-auto">
  <div class="container max-w-[1280px] py-12 md:py-16">
    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-4">
      <div class="space-y-4">
        <div class="flex items-center gap-3">
          <span class="inline-flex items-center justify-center w-16 h-16 rounded-xl bg-white p-1">
            <img src={`${import.meta.env.BASE_URL}images/logo/sara-logo.jpg`} alt={SITE.name[lang]} class="w-full h-full object-contain rounded-md" />
          </span>
          <div>
            <p class="font-bold text-lg">{SITE.shortName[lang]}</p>
            <p class="text-xs text-white/70">{t('tagline')}</p>
          </div>
        </div>
        <p class="text-sm text-white/80 leading-relaxed">{t('about.missionText')}</p>
      </div>

      <div>
        <h3 class="font-bold mb-4 text-teal">{t('footer.quickLinks')}</h3>
        <ul class="space-y-2 text-sm">
          {quickLinks.map((link) => (
            <li><a href={link.href} class="text-white/80 hover:text-teal transition-colors">{t(link.key)}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="font-bold mb-4 text-teal">{t('footer.contactInfo')}</h3>
        <ul class="space-y-3 text-sm">
          <li class="flex items-start gap-2">
            <Icon name="phone" size={18} class="mt-0.5 flex-shrink-0 text-teal" />
            <a href={SITE.phone.tel} class="text-white/90 hover:text-teal" dir="ltr">{SITE.phone.display}</a>
          </li>
          <li class="flex items-start gap-2">
            <Icon name="map-pin" size={18} class="mt-0.5 flex-shrink-0 text-teal" />
            <span class="text-white/90">{SITE.address[lang]}</span>
          </li>
          <li class="flex items-start gap-2">
            <Icon name="mail" size={18} class="mt-0.5 flex-shrink-0 text-teal" />
            <a href={`mailto:${SITE.email}`} class="text-white/90 hover:text-teal" dir="ltr">{SITE.email}</a>
          </li>
        </ul>
        <div class="mt-4">
          <p class="font-semibold mb-2 text-sm text-teal">{t('footer.followUs')}</p>
          <a
            href={SITE.social.facebook}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook"
            class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-white/10 hover:bg-teal hover:text-navy transition-colors"
          >
            <Icon name="facebook" size={20} />
          </a>
        </div>
      </div>

      <div>
        <h3 class="font-bold mb-4 text-teal">{t('footer.hours')}</h3>
        <ul class="space-y-2 text-sm">
          {hours.map((row) => (
            <li class="flex justify-between gap-3">
              <span class="text-white/80">{row.label}</span>
              <span class="font-medium" dir="ltr">{row.value}</span>
            </li>
          ))}
        </ul>
        <p class="mt-3 text-xs text-teal">{t('hours.emergencyAvailable')}</p>
      </div>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="container max-w-[1280px] py-6 flex flex-col md:flex-row md:items-center md:justify-between gap-3 text-xs text-white/60">
      <p>© {year} {SITE.name[lang]}. {t('footer.rights')}.</p>
      <ul class="flex gap-4">
        <li><a href={`${import.meta.env.BASE_URL}${lang}/privacy`} class="hover:text-teal">{t('footer.privacyPolicy')}</a></li>
        <li><a href={`${import.meta.env.BASE_URL}${lang}/accessibility`} class="hover:text-teal">{t('footer.accessibility')}</a></li>
      </ul>
    </div>
  </div>
</footer>
