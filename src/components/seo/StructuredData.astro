---
import { SITE } from '~/config/site';
import { getLangFromUrl, type LanguageCode } from '@i18n/utils';

interface Props {
  type?: 'organization' | 'article' | 'physician';
  data?: Record<string, unknown>;
}

const { type = 'organization', data = {} } = Astro.props;
const lang = (Astro.currentLocale as LanguageCode) ?? getLangFromUrl(Astro.url);

const organizationJsonLd = {
  '@context': 'https://schema.org',
  '@type': ['MedicalBusiness', 'EmergencyService'],
  '@id': `${SITE.url}/#organization`,
  name: SITE.name[lang],
  alternateName: [SITE.name.ar, SITE.name.he, SITE.name.en],
  url: SITE.url,
  logo: `${SITE.url}/images/logo/sara-logo.jpg`,
  image: `${SITE.url}${SITE.defaultOgImage}`,
  telephone: SITE.phone.intl,
  email: SITE.email,
  address: {
    '@type': 'PostalAddress',
    streetAddress: SITE.address.street,
    addressLocality: SITE.address.locality,
    addressRegion: 'Haifa District',
    addressCountry: SITE.address.country,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: SITE.geo.latitude,
    longitude: SITE.geo.longitude,
  },
  openingHoursSpecification: [
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Sunday','Monday','Tuesday','Wednesday','Thursday'], opens: '08:00', closes: '22:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: 'Friday', opens: '08:00', closes: '14:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: 'Saturday', opens: '08:30', closes: '18:00' },
  ],
  medicalSpecialty: ['Pediatrics', 'EmergencyMedicine', 'ObstetricsAndGynecology', 'PrimaryCare'],
  sameAs: [SITE.social.facebook],
  availableService: [
    { '@type': 'MedicalProcedure', name: 'Emergency Care' },
    { '@type': 'MedicalProcedure', name: 'Pediatric Care' },
    { '@type': 'MedicalProcedure', name: 'Pregnancy & Women\'s Health' },
  ],
};

const finalJsonLd = type === 'organization' ? organizationJsonLd : { ...organizationJsonLd, ...data };
---

<script type="application/ld+json" set:html={JSON.stringify(finalJsonLd)} />
