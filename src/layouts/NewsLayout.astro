---
import PageLayout from './PageLayout.astro';
import { useTranslations, type LanguageCode } from '@i18n/utils';
import { getLangFromUrl } from '@i18n/utils';
import Badge from '@components/ui/Badge.astro';
import Icon from '@components/ui/Icon.astro';
import Button from '@components/ui/Button.astro';
import { SITE } from '~/config/site';

interface Props {
  title: string;
  description: string;
  excerpt: string;
  publishDate: Date;
  updatedDate?: Date;
  tags?: string[];
  featured?: boolean;
  image?: string;
}
const { title, description, excerpt, publishDate, updatedDate, tags = [], featured, image } = Astro.props;
const lang = (Astro.currentLocale as LanguageCode) ?? getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const localeCode = lang === 'ar' ? 'ar-EG' : lang === 'he' ? 'he-IL' : 'en-US';
const formattedDate = new Intl.DateTimeFormat(localeCode, { year: 'numeric', month: 'long', day: 'numeric' }).format(publishDate);

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: title,
  description: excerpt,
  datePublished: publishDate.toISOString(),
  dateModified: (updatedDate ?? publishDate).toISOString(),
  author: { '@type': 'Organization', name: SITE.name[lang] },
  publisher: { '@id': `${SITE.url}/#organization` },
};
---
<PageLayout
  title={title}
  description={description}
  image={image}
  type="article"
  publishDate={publishDate}
  modifiedDate={updatedDate}
  jsonLdData={articleJsonLd}
>
  <section class="bg-navy text-white">
    <div class="container max-w-3xl py-12 md:py-16">
      <nav aria-label="breadcrumb" class="text-sm text-white/60 mb-6">
        <a href={`/${lang}/`} class="hover:text-teal">{t('nav.home')}</a>
        <span class="mx-2">/</span>
        <a href={`/${lang}/news/`} class="hover:text-teal">{t('nav.news')}</a>
      </nav>
      <div class="flex flex-wrap gap-2 mb-4">
        {featured && <Badge variant="teal" class="bg-teal text-navy">{t('common.new')}</Badge>}
        {tags.map((tag) => (
          <Badge variant="navy" class="bg-white/15 text-white">{tag}</Badge>
        ))}
      </div>
      <h1 class="text-3xl md:text-4xl font-bold text-balance">{title}</h1>
      <div class="mt-4 flex items-center gap-2 text-white/70 text-sm">
        <Icon name="calendar" size={16} />
        <time datetime={publishDate.toISOString()}>{formattedDate}</time>
      </div>
    </div>
  </section>

  <article class="section">
    <div class="container max-w-3xl">
      <div class="news-content text-lg leading-relaxed text-ink space-y-5">
        <slot />
      </div>

      <div class="mt-12 pt-8 border-t border-surface-tint flex flex-wrap gap-3">
        <Button variant="primary" href={`/${lang}/news/`}>
          <Icon name="arrow-end" size={16} class="rotate-180 icon-flip-rtl" />
          {t('nav.news')}
        </Button>
        <Button variant="teal" href={`/${lang}/booking`}>
          <Icon name="calendar" size={16} />
          {t('common.bookNow')}
        </Button>
      </div>
    </div>
  </article>
</PageLayout>

<style>
  .news-content :global(h2) {
    @apply text-2xl font-bold text-navy mt-8 mb-3;
  }
  .news-content :global(h3) {
    @apply text-xl font-bold text-navy mt-6 mb-2;
  }
  .news-content :global(p) {
    @apply mb-4 text-ink-muted;
  }
  .news-content :global(ul) {
    @apply list-disc ps-6 space-y-2 mb-4 text-ink-muted;
  }
  .news-content :global(ol) {
    @apply list-decimal ps-6 space-y-2 mb-4 text-ink-muted;
  }
  .news-content :global(a) {
    @apply text-teal-700 underline hover:text-teal-600;
  }
  .news-content :global(blockquote) {
    @apply border-s-4 border-teal ps-4 italic text-ink-muted my-6;
  }
  .news-content :global(strong) {
    @apply text-navy font-bold;
  }
</style>
