---
import PageLayout from '@layouts/PageLayout.astro';
import Heading from '@components/ui/Heading.astro';
import { useTranslations } from '@i18n/utils';

const lang = 'en';
const t = useTranslations(lang);
---
<PageLayout title={t('privacy.pageTitle')} description={t('privacy.intro')}>
  <section class="bg-navy text-white">
    <div class="container max-w-3xl py-10 md:py-14">
      <Heading level={1} size="lg" align="start">{t('privacy.pageTitle')}</Heading>
    </div>
  </section>
  <section class="section">
    <div class="container max-w-3xl space-y-4 text-ink-muted leading-relaxed text-lg">
      <p>{t('privacy.intro')}</p>
      <h2 class="text-2xl font-bold text-navy mt-8">Information Collection</h2>
      <p>We collect personal information that you voluntarily provide when filling out contact forms or booking appointments. This information includes: name, phone number, email, and any additional information you choose to share.</p>
      <h2 class="text-2xl font-bold text-navy mt-8">Use of Information</h2>
      <p>We use your information only to contact you, confirm appointments, and provide medical services. We do not share your data with third parties without your explicit consent, except as required by law.</p>
      <h2 class="text-2xl font-bold text-navy mt-8">Your Rights</h2>
      <p>You have the right to access your data, edit it, or request its deletion at any time. You can contact us at 04-884-8080.</p>
      <h2 class="text-2xl font-bold text-navy mt-8">Security</h2>
      <p>We take reasonable measures to protect your data from unauthorized access, disclosure, or alteration.</p>
    </div>
  </section>
</PageLayout>
