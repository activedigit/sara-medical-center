---
import { getCollection } from 'astro:content';
import PageLayout from '@layouts/PageLayout.astro';
import Heading from '@components/ui/Heading.astro';
import Card from '@components/ui/Card.astro';
import Icon from '@components/ui/Icon.astro';
import Badge from '@components/ui/Badge.astro';
import { useTranslations } from '@i18n/utils';

const lang = 'en';
const t = useTranslations(lang);
const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);
---
<PageLayout title={t('nav.services')} description={t('services.sectionSubtitle')}>
  <section class="bg-navy text-white">
    <div class="container max-w-[1280px] py-12 md:py-16">
      <Heading level={1} size="xl" eyebrow={t('nav.services')} subtitle={t('services.sectionSubtitle')} align="start">
        {t('services.sectionTitle')}
      </Heading>
    </div>
  </section>
  <section class="section">
    <div class="container max-w-[1280px]">
      <div class="grid gap-5 md:grid-cols-2">
        {services.map((service) => (
          <Card href={`${import.meta.env.BASE_URL}/${lang}/services/${service.data.slug}`} variant="outline" padding="lg" hoverable={true} class="group h-full flex flex-col">
            <div class="flex items-start justify-between mb-4">
              <span class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-navy/5 text-navy group-hover:bg-navy group-hover:text-teal transition-colors">
                <Icon name={service.data.icon} size={28} />
              </span>
              {service.data.free && <Badge variant="success">{t('common.free')}</Badge>}
            </div>
            <h2 class="text-xl font-bold text-navy mb-2">{service.data.title[lang]}</h2>
            <p class="text-ink-muted leading-relaxed flex-1">{service.data.shortDescription[lang]}</p>
            {service.data.hours && (
              <p class="mt-3 text-sm text-teal-700 font-semibold flex items-center gap-1.5">
                <Icon name="clock" size={14} />
                {service.data.hours[lang]}
              </p>
            )}
            <div class="mt-4 inline-flex items-center gap-1.5 text-navy font-semibold group-hover:gap-2.5 transition-all">
              <span>{t('services.viewService')}</span>
              <Icon name="arrow-end" size={16} />
            </div>
          </Card>
        ))}
      </div>
    </div>
  </section>
</PageLayout>
