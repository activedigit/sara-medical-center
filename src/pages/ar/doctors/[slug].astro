---
import { getCollection, getEntry } from 'astro:content';
import PageLayout from '@layouts/PageLayout.astro';
import Card from '@components/ui/Card.astro';
import Button from '@components/ui/Button.astro';
import Icon from '@components/ui/Icon.astro';
import Badge from '@components/ui/Badge.astro';
import DoctorAvatar from '@components/doctors/DoctorAvatar.astro';
import { useTranslations } from '@i18n/utils';
import { SITE } from '~/config/site';
import { languages } from '@i18n/languages';

export async function getStaticPaths() {
  const doctors = await getCollection('doctors');
  return doctors.map((doctor) => ({
    params: { slug: doctor.data.slug },
    props: { doctor },
  }));
}

const lang = 'ar';
const t = useTranslations(lang);
const { doctor } = Astro.props;
const data = doctor.data;

const relatedServices = await Promise.all(
  data.services.map(async (slug) => {
    try { return await getEntry('services', slug); } catch { return null; }
  })
);
const validServices = relatedServices.filter(Boolean);

const physicianJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Physician',
  name: data.name.en,
  alternateName: [data.name.ar, data.name.he],
  medicalSpecialty: data.specialty.en,
  worksFor: { '@id': `${SITE.url}/#organization` },
  knowsLanguage: data.languages,
};
---
<PageLayout title={data.name[lang]} description={data.shortBio[lang]} jsonLdData={physicianJsonLd}>
  <section class="bg-navy text-white">
    <div class="container max-w-[1280px] py-12 md:py-16">
      <nav aria-label="breadcrumb" class="text-sm text-white/60 mb-6">
        <a href={`/${lang}/`} class="hover:text-teal">{t('nav.home')}</a>
        <span class="mx-2">/</span>
        <a href={`/${lang}/doctors/`} class="hover:text-teal">{t('nav.doctors')}</a>
      </nav>
      <div class="flex flex-col md:flex-row items-start gap-6">
        <DoctorAvatar name={data.name.en} photo={data.photo} alt={data.portraitAlt ?? data.name[lang]} size="lg" />
        <div>
          <h1 class="text-3xl md:text-4xl font-bold mb-2">{data.name[lang]}</h1>
          <p class="text-teal text-lg font-semibold">{data.specialty[lang]}</p>
          <p class="mt-3 text-white/80 max-w-2xl leading-relaxed">{data.shortBio[lang]}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container max-w-[1280px] grid lg:grid-cols-3 gap-8">
      <div class="lg:col-span-2 space-y-6">
        <div>
          <h2 class="text-xl font-bold text-navy mb-3">{lang === 'ar' ? 'نبذة عن الطبيب' : 'About'}</h2>
          <p class="text-ink-muted leading-relaxed">{data.longBio[lang]}</p>
        </div>

        {data.credentials.length > 0 && (
          <Card variant="tint" padding="lg">
            <h3 class="text-lg font-bold text-navy mb-3">{t('doctors.credentials')}</h3>
            <ul class="space-y-2">
              {data.credentials.map((cred) => (
                <li class="flex items-center gap-2 text-ink">
                  <Icon name="check" size={16} class="text-accent-success" />
                  <span>{cred}</span>
                </li>
              ))}
            </ul>
          </Card>
        )}

        {validServices.length > 0 && (
          <div>
            <h3 class="text-lg font-bold text-navy mb-3">{t('nav.services')}</h3>
            <div class="grid sm:grid-cols-2 gap-3">
              {validServices.map((service) => (
                <Card href={`/${lang}/services/${service!.data.slug}`} variant="outline" padding="md" hoverable={true}>
                  <div class="flex items-center gap-3">
                    <span class="inline-flex items-center justify-center w-10 h-10 rounded-xl bg-navy/5 text-navy">
                      <Icon name={service!.data.icon} size={20} />
                    </span>
                    <span class="font-semibold text-navy">{service!.data.title[lang]}</span>
                  </div>
                </Card>
              ))}
            </div>
          </div>
        )}
      </div>

      <aside class="lg:col-span-1 space-y-4">
        {data.schedule && (
          <Card variant="default" padding="lg">
            <div class="flex items-center gap-2 mb-3">
              <Icon name="clock" size={20} class="text-navy" />
              <h3 class="font-bold text-navy">{t('hours.sectionTitle')}</h3>
            </div>
            <p class="text-ink">{data.schedule[lang]}</p>
          </Card>
        )}

        <Card variant="tint" padding="lg">
          <div class="flex items-center gap-2 mb-3">
            <Icon name="globe" size={20} class="text-navy" />
            <h3 class="font-bold text-navy">{t('doctors.languages')}</h3>
          </div>
          <div class="flex flex-wrap gap-2">
            {data.languages.map((langCode) => (
              <Badge variant="default" size="md">
                {languages[langCode as keyof typeof languages]?.nativeName ?? langCode}
              </Badge>
            ))}
          </div>
        </Card>

        <Card variant="default" padding="lg">
          <h3 class="font-bold text-navy mb-3">{t('common.bookNow')}</h3>
          <Button variant="teal" href={`/${lang}/booking?doctor=${data.slug}`} fullWidth={true}>
            <Icon name="calendar" size={18} />
            {t('common.bookNow')}
          </Button>
          <div class="mt-3 pt-3 border-t border-surface-tint flex flex-col gap-2">
            <Button variant="outline" href={SITE.phone.tel} fullWidth={true}>
              <Icon name="phone" size={16} />
              <span dir="ltr">{SITE.phone.display}</span>
            </Button>
          </div>
        </Card>
      </aside>
    </div>
  </section>
</PageLayout>
