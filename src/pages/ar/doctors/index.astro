---
import { getCollection } from 'astro:content';
import PageLayout from '@layouts/PageLayout.astro';
import Heading from '@components/ui/Heading.astro';
import Card from '@components/ui/Card.astro';
import Icon from '@components/ui/Icon.astro';
import DoctorAvatar from '@components/doctors/DoctorAvatar.astro';
import { useTranslations } from '@i18n/utils';

const lang = 'ar';
const t = useTranslations(lang);
const doctors = (await getCollection('doctors')).sort((a, b) => a.data.order - b.data.order);
---
<PageLayout title={t('nav.doctors')} description={t('doctors.sectionSubtitle')}>
  <section class="bg-navy text-white">
    <div class="container max-w-[1280px] py-12 md:py-16">
      <Heading level={1} size="xl" eyebrow={t('nav.doctors')} subtitle={t('doctors.sectionSubtitle')} align="start">
        {t('doctors.sectionTitle')}
      </Heading>
    </div>
  </section>

  <section class="section">
    <div class="container max-w-[1280px]">
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {doctors.map((doctor) => (
          <Card href={`${import.meta.env.BASE_URL}/${lang}/doctors/${doctor.data.slug}`} variant="default" padding="lg" hoverable={true} class="text-center">
            <DoctorAvatar name={doctor.data.name.en} photo={doctor.data.photo} alt={doctor.data.portraitAlt ?? doctor.data.name[lang]} size="sm" class="mx-auto mb-4" />
            <h2 class="text-lg font-bold text-navy">{doctor.data.name[lang]}</h2>
            <p class="text-sm text-teal-700 font-semibold mt-1">{doctor.data.specialty[lang]}</p>
            <p class="mt-3 text-sm text-ink-muted leading-relaxed">{doctor.data.shortBio[lang]}</p>
            {doctor.data.schedule && (
              <p class="mt-3 text-xs text-ink-subtle flex items-center justify-center gap-1.5">
                <Icon name="clock" size={12} />
                {doctor.data.schedule[lang]}
              </p>
            )}
          </Card>
        ))}
      </div>
    </div>
  </section>
</PageLayout>
