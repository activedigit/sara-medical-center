---
import PageLayout from '@layouts/PageLayout.astro';
import Heading from '@components/ui/Heading.astro';
import Card from '@components/ui/Card.astro';
import BookingForm from '@components/forms/BookingForm.astro';
import FormSuccess from '@components/forms/FormSuccess.astro';
import Icon from '@components/ui/Icon.astro';
import { useTranslations } from '@i18n/utils';

const lang = 'ar';
const t = useTranslations(lang);
const success = Astro.url.searchParams.get('success') === '1';
const preselectedService = Astro.url.searchParams.get('service') ?? undefined;
const preselectedDoctor = Astro.url.searchParams.get('doctor') ?? undefined;
const instructions = (t('booking.instructions') as unknown as string[] | string);
const instructionsList: string[] = Array.isArray(instructions) ? instructions : [
  'الحجز لا يضمن الموعد إلا بعد تأكيد طاقم المركز.',
  'للحالات الطارئة، يرجى الاتصال مباشرة على 04-884-8080.',
  'احضر بطاقة الهوية وبطاقة صندوق المرضى.',
];
---
<PageLayout title={t('booking.pageTitle')} description={t('booking.pageSubtitle')}>
  <section class="bg-navy text-white">
    <div class="container max-w-[1280px] py-12 md:py-16">
      <Heading level={1} size="xl" eyebrow={t('nav.booking')} subtitle={t('booking.pageSubtitle')} align="start">
        {t('booking.pageTitle')}
      </Heading>
    </div>
  </section>

  <section class="section">
    <div class="container max-w-[1280px]">
      {success && <div class="mb-10"><FormSuccess lang={lang} /></div>}

      <div class="grid lg:grid-cols-3 gap-8">
        <div class="lg:col-span-2">
          <Card variant="default" padding="lg">
            <BookingForm lang={lang} preselectedService={preselectedService} preselectedDoctor={preselectedDoctor} />
          </Card>
        </div>
        <aside class="lg:col-span-1 space-y-4">
          <Card variant="tint" padding="lg">
            <div class="flex items-center gap-2 mb-3">
              <Icon name="check" size={20} class="text-accent-success" />
              <h3 class="font-bold text-navy">{t('booking.instructionsTitle')}</h3>
            </div>
            <ul class="space-y-2 text-sm text-ink-muted">
              {instructionsList.map((line) => (
                <li class="flex items-start gap-2">
                  <span class="inline-block w-1.5 h-1.5 rounded-full bg-teal mt-2 flex-shrink-0"></span>
                  <span>{line}</span>
                </li>
              ))}
            </ul>
          </Card>
        </aside>
      </div>
    </div>
  </section>
</PageLayout>
