---
import PageLayout from '@layouts/PageLayout.astro';
import Heading from '@components/ui/Heading.astro';
import Card from '@components/ui/Card.astro';
import Icon from '@components/ui/Icon.astro';
import { useTranslations } from '@i18n/utils';
import { SITE } from '~/config/site';

const lang = 'ar';
const t = useTranslations(lang);

const values = [
  { key: 'professionalism', icon: 'stethoscope' },
  { key: 'compassion', icon: 'heart' },
  { key: 'accessibility', icon: 'check' },
];
---
<PageLayout title={t('about.pageTitle')} description={t('about.pageSubtitle')}>
  <section class="bg-navy text-white">
    <div class="container max-w-[1280px] py-12 md:py-16">
      <Heading level={1} size="xl" eyebrow={t('nav.about')} subtitle={t('about.pageSubtitle')} align="start">
        {t('about.pageTitle')}
      </Heading>
    </div>
  </section>

  <section class="section">
    <div class="container max-w-[1280px]">
      <div class="grid md:grid-cols-2 gap-6 mb-12">
        <Card variant="tint" padding="lg">
          <h2 class="text-2xl font-bold text-navy mb-3">{t('about.missionTitle')}</h2>
          <p class="text-ink-muted leading-relaxed">{t('about.missionText')}</p>
        </Card>
        <Card variant="default" padding="lg">
          <h2 class="text-2xl font-bold text-navy mb-3">{t('about.visionTitle')}</h2>
          <p class="text-ink-muted leading-relaxed">{t('about.visionText')}</p>
        </Card>
      </div>

      <h2 class="text-2xl md:text-3xl font-bold text-navy text-center mb-8">{t('about.valuesTitle')}</h2>
      <div class="grid sm:grid-cols-3 gap-5">
        {values.map((v) => (
          <Card variant="default" padding="lg" class="text-center">
            <span class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-teal/15 text-teal-700 mb-4">
              <Icon name={v.icon} size={28} />
            </span>
            <h3 class="text-lg font-bold text-navy mb-2">{t(`about.values.${v.key}`)}</h3>
            <p class="text-sm text-ink-muted leading-relaxed">{t(`about.values.${v.key}Text`)}</p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-surface-alt">
    <div class="container max-w-[1280px] grid lg:grid-cols-2 gap-8 items-center">
      <div>
        <p class="eyebrow">{t('common.new')}</p>
        <h2 class="text-2xl md:text-3xl font-bold text-navy mt-2 mb-4">{lang === 'ar' ? 'موقعنا' : ''}</h2>
        <p class="text-ink-muted leading-relaxed mb-4">{SITE.address[lang]}</p>
        <p class="text-sm text-ink-subtle">{lang === 'ar' ? 'مقابل عيادة מאוחדת' : ''}</p>
      </div>
      <Card variant="default" padding="lg">
        <p class="font-bold text-navy mb-2">{lang === 'ar' ? 'الاتصال السريع' : ''}</p>
        <a href={SITE.phone.tel} class="block text-2xl font-bold text-navy hover:text-teal-700 mb-4" dir="ltr">{SITE.phone.display}</a>
        <p class="text-sm text-ink-muted">{t('hours.emergencyAvailable')}</p>
      </Card>
    </div>
  </section>
</PageLayout>
