---
import PageLayout from '@layouts/PageLayout.astro';
import Heading from '@components/ui/Heading.astro';
import { useTranslations } from '@i18n/utils';

const lang = 'ar';
const t = useTranslations(lang);
---
<PageLayout title={t('privacy.pageTitle')} description={t('privacy.intro')}>
  <section class="bg-navy text-white">
    <div class="container max-w-3xl py-10 md:py-14">
      <Heading level={1} size="lg" align="start">{t('privacy.pageTitle')}</Heading>
    </div>
  </section>
  <section class="section">
    <div class="container max-w-3xl space-y-4 text-ink-muted leading-relaxed text-lg">
      <p>{t('privacy.intro')}</p>
      <h2 class="text-2xl font-bold text-navy mt-8">جمع المعلومات</h2>
      <p>نقوم بجمع المعلومات الشخصية التي تقدمها لنا طوعاً عند تعبئة نماذج الاتصال أو حجز المواعيد. تشمل هذه المعلومات: الاسم، رقم الهاتف، البريد الإلكتروني، وأي معلومات إضافية تختار مشاركتها.</p>
      <h2 class="text-2xl font-bold text-navy mt-8">استخدام المعلومات</h2>
      <p>نستخدم معلوماتك فقط لأغراض التواصل معك، تأكيد المواعيد، وتقديم الخدمات الطبية. لا نشارك بياناتك مع أطراف ثالثة بدون موافقتك الصريحة، باستثناء ما يقتضيه القانون.</p>
      <h2 class="text-2xl font-bold text-navy mt-8">حقوقك</h2>
      <p>لك الحق في الاطلاع على بياناتك، تعديلها، أو طلب حذفها في أي وقت. يمكنك التواصل معنا عبر الهاتف 04-884-8080.</p>
      <h2 class="text-2xl font-bold text-navy mt-8">الأمان</h2>
      <p>نتخذ تدابير معقولة لحماية بياناتك من الوصول غير المصرح به أو الإفصاح أو التغيير.</p>
    </div>
  </section>
</PageLayout>
