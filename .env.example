# Site URL (production)
PUBLIC_SITE_URL=https://saramedical.co.il

# Contact email (for Netlify Forms notifications - configure in Netlify dashboard)
PUBLIC_CONTACT_EMAIL=info@saramedical.co.il

# WhatsApp number (international format, no '+', no dashes - this is what wa.me/ accepts)
# Example: 972548848080 (Israel country code 972 + number without leading 0)
PUBLIC_WHATSAPP_NUMBER=97248848080

# Phone number (international format with '+' for tel: links and display)
PUBLIC_PHONE_NUMBER=+97248848080
PUBLIC_PHONE_DISPLAY=04-884-8080
